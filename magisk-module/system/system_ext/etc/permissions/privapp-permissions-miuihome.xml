<?xml version="1.0" encoding="utf-8"?>
<!--
    privapp-permissions-miuihome.xml
    MiuiHome Launcher Port — HyperOS 3 → AOSP Android 16

    Letakkan di: /system/system_ext/etc/permissions/
    (sudah otomatis via Magisk module overlay)

    Tanpa file ini, MiuiHome akan ditolak saat pakai
    privileged permissions dan crash saat startup.
-->
<permissions>
    <privapp-permissions package="com.miui.home">

        <!-- Core launcher permissions -->
        <permission name="android.permission.BIND_APPWIDGET"/>
        <permission name="android.permission.SET_WALLPAPER"/>
        <permission name="android.permission.SET_WALLPAPER_HINTS"/>
        <permission name="android.permission.SET_WALLPAPER_COMPONENT"/>
        <permission name="android.permission.EXPAND_STATUS_BAR"/>
        <permission name="android.permission.READ_PHONE_STATE"/>
        <permission name="android.permission.RECEIVE_BOOT_COMPLETED"/>
        <permission name="android.permission.WRITE_SECURE_SETTINGS"/>
        <permission name="android.permission.READ_DEVICE_CONFIG"/>
        <permission name="android.permission.BIND_WALLPAPER"/>
        <permission name="android.permission.SET_PROCESS_LIMIT"/>
        <permission name="android.permission.MOUNT_UNMOUNT_FILESYSTEMS"/>

        <!-- Task management (Recents) -->
        <permission name="android.permission.MANAGE_ACTIVITY_TASKS"/>
        <permission name="android.permission.MANAGE_ACTIVITY_STACKS"/>
        <permission name="android.permission.START_TASKS_FROM_RECENTS"/>
        <permission name="android.permission.REAL_GET_TASKS"/>
        <permission name="android.permission.GET_TASKS"/>
        <permission name="android.permission.REORDER_TASKS"/>
        <permission name="android.permission.REMOVE_TASKS"/>

        <!-- Package manager -->
        <permission name="android.permission.QUERY_ALL_PACKAGES"/>
        <permission name="android.permission.DELETE_PACKAGES"/>
        <permission name="android.permission.CHANGE_COMPONENT_ENABLED_STATE"/>
        <permission name="android.permission.FORCE_STOP_PACKAGES"/>

        <!-- System UI interactions -->
        <permission name="android.permission.STATUS_BAR"/>
        <permission name="android.permission.STATUS_BAR_SERVICE"/>
        <permission name="android.permission.INTERNAL_SYSTEM_WINDOW"/>
        <permission name="android.permission.SYSTEM_ALERT_WINDOW"/>
        <permission name="android.permission.INTERACT_ACROSS_USERS"/>
        <permission name="android.permission.INTERACT_ACROSS_USERS_FULL"/>
        <permission name="android.permission.BROADCAST_CLOSE_SYSTEM_DIALOGS"/>
        <permission name="android.permission.START_ANY_ACTIVITY"/>

        <!-- Users & accessibility -->
        <permission name="android.permission.MANAGE_USERS"/>
        <permission name="android.permission.MANAGE_ACCESSIBILITY"/>
        <permission name="android.permission.MANAGE_ROLE_HOLDERS"/>

        <!-- App usage stats (for recents/suggestions) -->
        <permission name="android.permission.PACKAGE_USAGE_STATS"/>
        <permission name="android.permission.UPDATE_APP_OPS_STATS"/>
        <permission name="android.permission.UPDATE_DEVICE_STATS"/>

        <!-- Misc -->
        <permission name="android.permission.BROADCAST_STICKY"/>
        <permission name="android.permission.CHANGE_CONFIGURATION"/>
        <permission name="android.permission.INJECT_EVENTS"/>
        <permission name="android.permission.READ_FRAME_BUFFER"/>
        <permission name="android.permission.DUMP"/>
        <permission name="android.permission.SET_ACTIVITY_WATCHER"/>
        <permission name="android.permission.WAKE_LOCK"/>
        <permission name="android.permission.VIBRATE"/>
        <permission name="android.permission.INTERNET"/>
        <permission name="android.permission.POST_NOTIFICATIONS"/>
        <permission name="android.permission.ACCESS_NETWORK_STATE"/>
        <permission name="android.permission.READ_SYNC_SETTINGS"/>
        <permission name="android.permission.SUBSCRIBE_TO_KEYGUARD_LOCKED_STATE"/>
        <permission name="android.permission.CONTROL_REMOTE_APP_TRANSITION_ANIMATIONS"/>
        <permission name="android.permission.ALLOW_SLIPPERY_TOUCHES"/>
        <permission name="android.permission.ACCESS_SHORTCUTS"/>
        <permission name="android.permission.UNLIMITED_TOASTS"/>
        <permission name="android.permission.GET_DETAILED_TASKS"/>
        <permission name="android.permission.LOG_COMPAT_CHANGE"/>
        <permission name="android.permission.READ_COMPAT_CHANGE_CONFIG"/>
        <permission name="android.permission.MEDIA_CONTENT_CONTROL"/>
        <permission name="android.permission.READ_MIPOCKET"/>

    </privapp-permissions>
</permissions>
